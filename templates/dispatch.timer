[Unit]
Description=DevFlow AFK Dispatch — {{PROJECT_NAME}}
After=network.target

[Service]
Type=oneshot
User=www
WorkingDirectory={{PROJECT_WORKSPACE}}
ExecStart=/bin/bash {{PROJECT_WORKSPACE}}/.devflow/archon/dispatch.sh {{PROJECT_WORKSPACE}}
StandardOutput=append:{{PROJECT_WORKSPACE}}/logs/dispatch.log
StandardError=append:{{PROJECT_WORKSPACE}}/logs/dispatch.log
