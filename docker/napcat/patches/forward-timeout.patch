# napcat forward-timeout patch
# 修复 getMultiMessages 无超时导致单群静默
# 适用版本：napcat 打包版（napcat.mjs 单文件）

# 简介
# －Patch 1a: getMultiMessages 加 10s Promise.race 超时
# --Patch 1b: FetchForwardMsg fallback 加 5s Promise.race 超时

# Patch 1a: getMultiMessages 超时
# L106250: let multiMsgs = await this.getMultiMessages(msg, parentMsgPeer);
# → Promise.race([..., new Promise(r => setTimeout(r(null), 10000))])

# Patch 1b: FetchForwardMsg fallback 超时
# L106253: multiMsgs = await this.core.apis.PacketApi.pkt.operation.FetchForwardMsg(element.resId);
# → Promise.race([..., new Promise(r => setTimeout(r(null), 5000))])

# 验证字符串：getMultiMessages 10s Promise.race
# 验证字符串：FetchForwardMsg 5s Promise.race
